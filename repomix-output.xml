import React, { useEffect, useState } from 'react'
import { MapContainer, TileLayer, Marker, Polyline, useMap, useMapEvents } from 'react-leaflet'
import L from 'leaflet'
import locations from '../../json/locations.json'
import markerIcon from 'leaflet/dist/images/marker-icon.png'

/*
 * ملف MapComponent مسؤول عن عرض خريطة Leaflet، العلامات الثابتة،
 * نقاط الرحلة، وخط المسار عند توفره.
 */
// مركز افتراضي للخريطة عند التحميل، ويُستخدم كـ fallback قبل تثبيت bounds على النقاط المختارة.
const EL_ARISH_CENTER = [31.1285, 33.8015]

// MAP_STYLES تربط اسم التصميم بعنوان tile layer المناسب، ويختاره الـ UI عبر prop mapStyle.
const MAP_STYLES = {
  standard: { url: 'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', attribution: '&copy; OpenStreetMap' },
  satellite: { url: 'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', attribution: 'Tiles &copy; Esri' },
  terrain: { url: 'https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png', attribution: '&copy; OpenTopoMap' },
  dark: { url: 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', attribution: '&copy; CARTO' },
}

// ClickCapture يلتقط نقرة الخريطة ويرسل latlng إلى onPick القادم من الصفحة الأب.
const ClickCapture = ({ onPick }) => {
  useMapEvents({
    click: (e) => onPick && onPick(e.latlng),
  })
  return null
}

// FitToPoints يستقبل points من MapComponent ويضبط zoom/bounds ليحتوي كل النقاط الظاهرة.
const FitToPoints = ({ points }) => {
  const map = useMap()
  useEffect(() => {
    if (!points || points.length === 0) return
    if (points.length === 1) {
      map.setView(points[0], 15)
      return
    }
    map.fitBounds(points, { padding: [60, 60] })
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [JSON.stringify(points)])
  return null
}

const TRIP_MARKER_STYLES = {
  start: { color: '#22c55e', label: 'ب' },
  end: { color: '#ef4444', label: 'ن' },
  waypoint: { color: '#f59e0b', label: 'م' },
}

const createTripMarkerIcon = (type) => {
  const style = TRIP_MARKER_STYLES[type] || TRIP_MARKER_STYLES.waypoint
  return L.divIcon({
    className: '',
    html: `
      <div style="position:relative;width:30px;height:42px;transform:translateY(-4px)">
        <div style="position:absolute;inset:0;background:${style.color};border:3px solid #0f172a;border-radius:999px 999px 999px 0;transform:rotate(-45deg);"></div>
        <div style="position:absolute;left:50%;top:38%;transform:translate(-50%,-50%);width:18px;height:18px;border-radius:999px;background:#0f172a;color:${style.color};display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;line-height:1;">${style.label}</div>
      </div>
    `,
    iconSize: [30, 42],
    iconAnchor: [15, 38],
  })
}

  // LABEL_HIDE_ZOOM هو أدنى مستوى zoom يسمح بإظهار أسماء المواقع على markers المواقع الثابتة.
export const LABEL_HIDE_ZOOM = 15

/**
 * MapMarkers
   * هذا المكوّن يقرأ المواقع الثابتة من locations.json ويحوّلها إلى markers.
   * مصدر البيانات هو الملف المحلي JSON، بينما حالة zoom تأتي من MapContainer نفسه.
 */
const MapMarkers = () => {
  const map = useMap()
  const [zoom, setZoom] = useState(map.getZoom())

  useEffect(() => {
    const onZoom = () => setZoom(map.getZoom())
    map.on('zoomend', onZoom)
    return () => map.off('zoomend', onZoom)
  }, [map])

  // getLabelFontSize يحسب font-size انطلاقًا من zoom الحالي ليحافظ على قابلية القراءة.
  const getLabelFontSize = () => Math.max(10, Math.min(14, 9 + (zoom - LABEL_HIDE_ZOOM) * 0.6))

  // createIcon يستقبل label من locations.json و showMarker من حالة zoom ليكوّن divIcon مناسب.
  const createIcon = (label, showMarker) =>
    L.divIcon({
      className: '',
      html: showMarker
        ? `<div class="map-location-marker">
             <img class="map-marker-icon map-marker-icon-small" src="${markerIcon}" alt="${label}" />
             <div class="map-label" style="font-size:${getLabelFontSize()}px">${label}</div>
           </div>`
        : '',
      iconSize: showMarker ? [170, 36] : [1, 1],
      iconAnchor: showMarker ? [10, 18] : [0, 0],
    })

  return (
    <>
      {locations.map((loc, i) => {
        const [lat, lng] = loc.coords
        const name = Array.isArray(loc.name) ? loc.name[0] : loc.name || loc.section || loc.category
        const showMarker = zoom >= LABEL_HIDE_ZOOM
        return <Marker key={i} position={[lat, lng]} icon={createIcon(name, showMarker)} />
      })}
    </>
  )
}

/**
 * MapComponent
 * props تأتي من الصفحة الأب مثل RequestTrip:
 * - startPin / endPin / waypoints من Redux أو state المحلية
 * - routeCoords من حساب المسار الخارجي
 * - pickTarget و onPick من وضع اختيار النقاط بالنقر
 * - mapStyle من اختيار المستخدم لتصميم الخريطة
 */
const MapComponent = ({ startPin, endPin, waypoints = [], routeCoords, pickTarget, onPick, mapStyle = 'dark' }) => {
  const layer = MAP_STYLES[mapStyle] || MAP_STYLES.dark
  const boundsPoints = [startPin, ...waypoints, endPin].filter(Boolean).map((p) => [p.lat, p.lng])

  return (
    <div style={{ height: '100%', width: '100%' }} className={`relative z-0 ${pickTarget ? 'cursor-crosshair' : ''}`}>
      <MapContainer center={EL_ARISH_CENTER} zoom={14} zoomControl={false} scrollWheelZoom style={{ height: '100%', width: '100%' }}>
        <TileLayer attribution={layer.attribution} url={layer.url} />

        {boundsPoints.length > 0 && <FitToPoints points={boundsPoints} />}

        {/* عرض الماركرات الثابتة من ملف locations.json */}
        <MapMarkers />

        {routeCoords && routeCoords.length > 1 && (
          <Polyline positions={routeCoords} pathOptions={{ color: '#10b981', weight: 5, opacity: 0.85 }} />
        )}

        {startPin && <Marker position={[startPin.lat, startPin.lng]} icon={createTripMarkerIcon('start')} />}

        {waypoints.map((wp, i) => (
          <Marker key={i} position={[wp.lat, wp.lng]} icon={createTripMarkerIcon('waypoint')} />
        ))}

        {endPin && <Marker position={[endPin.lat, endPin.lng]} icon={createTripMarkerIcon('end')} />}

        {pickTarget && <ClickCapture onPick={onPick} />}
      </MapContainer>
    </div>
  )
}

export default MapComponent
