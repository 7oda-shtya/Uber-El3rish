              </View>

              <Text className='text-left text-white/80 mb-2 text-xl'>كلمة المرور</Text>
              <View className='flex-row items-center rounded-2xl border border-white/10 bg-zinc-900/80 px-3 py-3'>
                <Ionicons name='lock-closed-outline' size={18} color='rgba(255,255,255,0.7)' />
                <TextInput placeholder='••••••••' placeholderTextColor='rgba(255,255,255,0.38)' secureTextEntry textAlign='right' className='outline-none flex-1 text-white text-base mx-3' />
                <Ionicons name='eye-outline' size={18} color='rgba(255,255,255,0.7)' />
