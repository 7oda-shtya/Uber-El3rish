{
  "expo": {
    "name": "verna",
    "slug": "verna",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "verna",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "predictiveBackGestureEnabled": false,
      "package": "verna.frontend",
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "output": "single"
    },
    "plugins": [
      "expo-font",
      "expo-image",
      "expo-status-bar",
      "expo-web-browser",
      "expo-background-task",
      "expo-secure-store"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "882ee230-3594-49d9-939c-17322e2e2f3f"
      }
    }
  }
}