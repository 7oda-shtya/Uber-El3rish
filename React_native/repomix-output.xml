<file path="src/client/components/Navigation.jsx">
import React, { useEffect, useRef, useState } from 'react';
import { View, Pressable, Text } from 'react-native';
import { Ionicons } from '@expo/vector-icons';
import Animated, { useSharedValue, useAnimatedStyle, withTiming, Easing } from 'react-native-reanimated';

const TABS = [
  { name: 'Home', icon: 'home-outline', color: '#22D3EE' },
  { name: 'History', icon: 'time-outline', color: '#A3E635' },
  { name: 'Favorites', icon: 'heart-outline', color: '#F472B6' },
  { name: 'Profile', icon: 'person-outline', color: '#FACC15' },
];

const ARC_HEIGHT = 22;
const ANIM_DURATION = 400;

// دلوقتي بترجع تاخد state و navigation تلقائيًا من الـ Tab.Navigator نفسه (زي الأول بالظبط)
// لأنها بقت شغالة كـ tabBar prop مش بتترندر يدويًا من جوه كل شاشة
const Navigation = ({ state, navigation }) => {
  const tabPositions = useRef([]);
  const [measuredCount, setMeasuredCount] = useState(0);

  const indicatorX = useSharedValue(0);
  const arcProgress = useSharedValue(0);
  const activeColor = useSharedValue(TABS[0].color);

  useEffect(() => {
    if (measuredCount === TABS.length && tabPositions.current[state.index] != null) {
      indicatorX.value = tabPositions.current[state.index];
      activeColor.value = TABS[state.index].color;
    }
  }, [measuredCount]);

  // بيتابع لو الـ tab اتغيّر من مكان تاني (زي navigation.navigate من داخل شاشة)
  // مش بس من دوسة على الناف بار نفسها
  useEffect(() => {
    if (measuredCount === TABS.length && tabPositions.current[state.index] != null) {
      console.log('active index:', state.index, '→ target X:', tabPositions.current[state.index], '| كل المواقع:', tabPositions.current);
      indicatorX.value = withTiming(tabPositions.current[state.index], {
        duration: ANIM_DURATION,
        easing: Easing.inOut(Easing.quad),
      });
      arcProgress.value = 0;
      arcProgress.value = withTiming(1, { duration: ANIM_DURATION, easing: Easing.linear });
      activeColor.value = TABS[state.index].color;
    }
  }, [state.index]);

  const handleTabPress = (route, index) => {
    const isFocused = state.index === index;
    const event = navigation.emit({ type: 'tabPress', target: route.key, canPreventDefault: true });

    if (!isFocused && !event.defaultPrevented) {
      navigation.navigate(route.name);
    }
  };

  const indicatorStyle = useAnimatedStyle(() => {
    const liftY = -Math.sin(arcProgress.value * Math.PI) * ARC_HEIGHT;
    return {
      transform: [{ translateX: indicatorX.value - 14 }, { translateY: liftY }],
      backgroundColor: activeColor.value,
    };
  });

  return (
    // position absolute + مسافات من الجوانب والأسفل = عائمة فوق المحتوى، مش لاصقة تحت
    <View style={{ position: 'absolute', left: 16, right: 16, bottom: 28 }} className='flex-row bg-zinc-900/95 border border-white/10 rounded-full px-2 py-3 shadow-2xl'>
      <Animated.View pointerEvents='none' style={[{ position: 'absolute', top: -2, right: 0, width: 28, height: 28, borderRadius: 14 }, indicatorStyle]} />

      {state.routes.map((route, index) => {
        const isFocused = state.index === index;
        const tab = TABS.find(t => t.name === route.name) ?? TABS[index];

        return (
          <Pressable
            key={route.key}
            onPress={() => handleTabPress(route, index)}
            onLayout={e => {
              const { x, width } = e.nativeEvent.layout;
              tabPositions.current[index] = x + width / 2;
              setMeasuredCount(c => c + 1);
            }}
            className='flex-1 items-center justify-center'>
            <Ionicons name={tab.icon} size={20} color={isFocused ? tab.color : 'rgba(255,255,255,0.4)'} />
          </Pressable>
        );
      })}
    </View>
  );
};

export default Navigation;
</file>

