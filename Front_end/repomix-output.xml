import { faChevronRight, faHouse, faBriefcase, faLocationDot, faTrash, faPlus, faPen } from '@fortawesome/free-solid-svg-icons'
import { addFavorite, removeFavorite, updateFavorite } from '../redux/reducers/authSlice'
