// src/components/trip/TripPlannerPanel.jsx
import React, { useState } from 'react';
import { FontAwesomeIcon } from '@fortawesome/react-fontawesome';
import {
  faMagnifyingGlass,
  faXmark,
  faPlus,
  faLocationCrosshairs,
  faLightbulb,
  faPen,
} from '@fortawesome/free-solid-svg-icons';
import LocationSearchInput from './LocationSearchInput';

const ONBOARDING_KEY = 'rt_trip_planner_onboarding_seen_v1';

/**
 * TripPlannerPanel
 * props:
 * - trip: كائن الرحلة الحالية (`currentTrip` من الـ Redux)
 * - pickTarget: الحالة التي تحدد أي نقطة يتم اختيارها عند النقر على الخريطة
 * - onSetPickTarget(target): تعيّن هدف الاختيار ('start' | 'end' | { waypoint: true })
 * - onSelectPlace(target, pin): تُستدعى عند اختيار مكان من مربع البحث بدل الخريطة
 * - onRemoveWaypoint(index): حذف محطة موجودة
 * - onConfirm(opts): تُستدعى عند تأكيد الطلب
 * - requesting: علم يوضح أن هناك عملية طلب جارية
 * - isTripSaved / onToggleSaveTrip: حفظ الرحلة
 */
const TripPlannerPanel = ({
  trip,
  pickTarget,
  onSetPickTarget,
  onSelectPlace,
  onRemoveWaypoint,
  onConfirm,
  requesting,
  isTripSaved,
  onToggleSaveTrip,
}) => {
  const isTripReady = trip.startPin && trip.endPin;
  const waypoints = trip.waypoints || [];

  const [showInfoModal, setShowInfoModal] = useState(false);
  const [searchTarget, setSearchTarget] = useState(null); // 'start' | 'end' | null
  const [scheduleType, setScheduleType] = useState('now');
  const [scheduleDay, setScheduleDay] = useState('today');
  const [scheduleTime, setScheduleTime] = useState('');
  const [customerNote, setCustomerNote] = useState('');
  const [passengerCount, setPassengerCount] = useState(1);

  const [showOnboarding, setShowOnboarding] = useState(() => {
    try {
      return !localStorage.getItem(ONBOARDING_KEY);
    } catch {
      return false;
    }
  });

  const dismissOnboarding = () => {
    try {
      localStorage.setItem(ONBOARDING_KEY, '1');
    } catch {
      /* لو الـ localStorage مش متاح، منمنعش المستخدم من الاستمرار */
    }
    setShowOnboarding(false);
  };

  // فتح/قفل مربع البحث لصف معيّن، وإلغاء وضع الاختيار من الخريطة إن كان شغال
  const toggleSearch = (target) => {
    setSearchTarget((prev) => (prev === target ? null : target));
    onSetPickTarget(null);
  };

  const toggleWaypointSearch = (index) => {
    const target = { waypoint: true, index }
    setSearchTarget((prev) => (prev?.waypoint && prev?.index === index ? null : target))
    onSetPickTarget(null)
  }

  // اختيار مكان من نتائج البحث
  const handlePlaceSelected = (target, place) => {
    const pin = {
      lat: place.lat,
      lng: place.lng,
      name: place.localName || place.fullName || 'موقع مختار',
    };
    onSelectPlace && onSelectPlace(target, pin);
    setSearchTarget(null);
  };

  // اختيار التحديد من الخريطة لصف معيّن
  const pickFromMap = (target) => {
    setSearchTarget(null);
    onSetPickTarget(target);
  };

  const isWaypointSearchTarget = searchTarget && typeof searchTarget === 'object' && searchTarget.waypoint

  return (
    <div className='absolute inset-x-0 top-16 z-30 flex flex-col items-center p-4 gap-3' dir='rtl'>
      {/* أونبوردنج بسيط يظهر أول مرة بس */}
      {showOnboarding && (
        <div className='fixed inset-0 z-[70] flex items-end sm:items-center justify-center p-4 bg-black/70 animate-fade-in'>
          <div className='w-full max-w-sm bg-zinc-900 border border-zinc-700/50 rounded-3xl p-5 shadow-2xl flex flex-col gap-4'>
            <div className='flex items-center gap-2 text-emerald-400'>
              <FontAwesomeIcon icon={faLightbulb} />
              <h3 className='text-sm font-bold text-white'>طلب الرحلة في 3 خطوات</h3>
            </div>
            <ul className='flex flex-col gap-3 text-xs text-zinc-300'>
              <li className='flex items-start gap-2'>
                <span className='w-5 h-5 rounded-full bg-emerald-600/20 text-emerald-400 flex items-center justify-center text-[10px] font-bold shrink-0'>1</span>
                حدد نقطة البداية والوصول: اكتبهم في مربع البحث أو اضغط مكانهم على الخريطة.
              </li>
              <li className='flex items-start gap-2'>
                <span className='w-5 h-5 rounded-full bg-blue-600/20 text-blue-400 flex items-center justify-center text-[10px] font-bold shrink-0'>2</span>
                تقدر تضيف محطة في الطريق لو محتاج تمر بمكان قبل الوصول.
              </li>
              <li className='flex items-start gap-2'>
                <span className='w-5 h-5 rounded-full bg-red-600/20 text-red-400 flex items-center justify-center text-[10px] font-bold shrink-0'>3</span>
                اضغط "تفاصيل الرحلة" لتأكيد الطلب وتحديد عدد الركاب والموعد.
              </li>
            </ul>
            <button onClick={dismissOnboarding} className='w-full bg-emerald-600 hover:bg-emerald-500 text-white rounded-xl py-2.5 text-sm font-bold transition-colors'>
              تمام، فهمت
            </button>
          </div>
        </div>
      )}

      {/* كارت من - إلى */}
      <div className='w-full max-w-sm bg-zinc-900/95 backdrop-blur-md border border-zinc-700/40 rounded-2xl shadow-xl overflow-hidden'>
        {/* صف البداية */}
        <div className={`flex items-center gap-3 px-3 py-3 border-b border-zinc-800 ${pickTarget === 'start' ? 'bg-emerald-950/30' : ''}`}>
          <span className='w-2.5 h-2.5 rounded-full bg-emerald-400 shrink-0' />
          <button onClick={() => pickFromMap('start')} className='flex-1 min-w-0 text-right'>
            <span className='block truncate text-sm text-white'>{trip.startPin?.name || 'من فين؟'}</span>
          </button>
          <button onClick={() => toggleSearch('start')} className={`w-8 h-8 rounded-lg flex items-center justify-center shrink-0 ${searchTarget === 'start' ? 'bg-emerald-600 text-white' : 'bg-zinc-800 text-zinc-400'}`}>
            <FontAwesomeIcon icon={searchTarget === 'start' ? faXmark : faMagnifyingGlass} className='text-xs' />
          </button>
        </div>
        {searchTarget === 'start' && (
          <div className='px-3 py-2 border-b border-zinc-800 bg-zinc-950/40'>
            <LocationSearchInput placeholder='اكتب اسم المكان...' onSelect={(place) => handlePlaceSelected('start', place)} />
          </div>
        )}

        {/* المحطات الموجودة */}
        {waypoints.map((wp, i) => (
          <div key={i} className='flex items-center gap-3 px-3 py-2.5 border-b border-zinc-800 bg-zinc-950/20'>
            <span className='w-2.5 h-2.5 rounded-full bg-blue-400 shrink-0' />
            <button onClick={() => toggleWaypointSearch(i)} className='flex-1 min-w-0 text-right'>
              <span className='block truncate text-xs text-zinc-300'>{wp.name}</span>
            </button>
            <button onClick={() => toggleWaypointSearch(i)} className='w-7 h-7 rounded-lg bg-zinc-800 text-zinc-500 hover:text-emerald-400 flex items-center justify-center shrink-0'>
              <FontAwesomeIcon icon={faPen} className='text-[10px]' />
            </button>
            <button onClick={() => onRemoveWaypoint && onRemoveWaypoint(i)} className='w-7 h-7 rounded-lg bg-zinc-800 text-zinc-500 hover:text-red-400 flex items-center justify-center shrink-0'>
              <FontAwesomeIcon icon={faXmark} className='text-[10px]' />
            </button>
          </div>
        ))}

        {/* صف الوصول */}
        <div className={`flex items-center gap-3 px-3 py-3 ${pickTarget === 'end' ? 'bg-red-950/30' : ''}`}>
          <span className='w-2.5 h-2.5 rounded-full bg-red-400 shrink-0' />
          <button onClick={() => pickFromMap('end')} className='flex-1 min-w-0 text-right'>
            <span className='block truncate text-sm text-white'>{trip.endPin?.name || 'رايح فين؟'}</span>
          </button>
          <button onClick={() => toggleSearch('end')} className={`w-8 h-8 rounded-lg flex items-center justify-center shrink-0 ${searchTarget === 'end' ? 'bg-red-600 text-white' : 'bg-zinc-800 text-zinc-400'}`}>
            <FontAwesomeIcon icon={searchTarget === 'end' ? faXmark : faMagnifyingGlass} className='text-xs' />
          </button>
        </div>
        {searchTarget === 'end' && (
          <div className='px-3 py-2 border-t border-zinc-800 bg-zinc-950/40'>
            <LocationSearchInput placeholder='اكتب اسم المكان...' onSelect={(place) => handlePlaceSelected('end', place)} />
          </div>
        )}

        {/* إضافة محطة */}
        <button onClick={() => toggleWaypointSearch(null)} className={`w-full flex items-center justify-center gap-2 py-2.5 text-xs font-bold border-t border-zinc-800 ${isWaypointSearchTarget ? 'bg-amber-950/30 text-amber-400' : 'text-zinc-400'}`}>
          <FontAwesomeIcon icon={faPlus} className='text-[10px]' /> إضافة محطة
        </button>
      </div>

      {isWaypointSearchTarget && (
        <div className='w-full max-w-sm bg-zinc-900/95 backdrop-blur-md border border-zinc-700/40 rounded-2xl shadow-xl overflow-hidden px-3 py-2'>
          <LocationSearchInput placeholder='اكتب اسم محطة الطريق...' onSelect={(place) => handlePlaceSelected(searchTarget, place)} />
        </div>
      )}

      {/* تلميح صغير وقت الاختيار من الخريطة */}
      {(pickTarget === 'start' || pickTarget === 'end' || pickTarget?.waypoint) && (
        <div className='bg-black/70 backdrop-blur-md text-white px-4 py-2 rounded-full text-xs font-bold border border-white/10 shadow-lg flex items-center gap-2'>
          <FontAwesomeIcon icon={faLocationCrosshairs} className='text-emerald-400' />
          اضغط على مكان على الخريطة
        </div>
      )}

      {isTripReady && (
        <>
          <button onClick={() => setShowInfoModal(true)} className='bg-emerald-600 hover:bg-emerald-500 text-white font-bold px-6 py-2.5 rounded-xl shadow-lg transition-colors'>
            تفاصيل الرحلة
          </button>

          {showInfoModal && (
            <div className='fixed inset-0 z-50 flex items-center justify-center p-4'>
              <div className='absolute inset-0 bg-black/60' onClick={() => setShowInfoModal(false)} />
              <div className='relative bg-zinc-900 border border-zinc-700/40 rounded-2xl w-full max-w-lg p-6 shadow-xl' dir='rtl'>
                <div className='flex items-center justify-between mb-3'>
                  <h3 className='text-lg font-bold'>تفاصيل الرحلة</h3>
                  <button onClick={() => setShowInfoModal(false)} className='text-zinc-400 hover:text-white'>إغلاق</button>
                </div>

                <div className='flex flex-col gap-2 text-sm text-zinc-300 mb-3'>
                  <div className='flex justify-between'><span>المسافة</span><span className='font-bold text-white'>{trip.route ? `${trip.route.distanceKm.toFixed(1)} كم` : '-'}</span></div>
                  <div className='flex justify-between'><span>المدة</span><span className='font-bold text-white'>{trip.route ? `${Math.round(trip.route.durationMin)} دقيقة` : '-'}</span></div>
                  <div className='flex justify-between'><span>السعر تقريبا</span><span className='font-bold text-white'>{trip.route ? `${trip.route.price} ج.م` : '-'}</span></div>
                </div>

                <div className='mb-3'>
                  <p className='text-sm text-zinc-400 mb-2'>موعد الرحلة</p>
                  <div className='flex items-center gap-4'>
                    <label className='flex items-center gap-2'><input type='radio' name='schedule' checked={scheduleType === 'now'} onChange={() => setScheduleType('now')} /> الآن</label>
                    <label className='flex items-center gap-2'><input type='radio' name='schedule' checked={scheduleType === 'later'} onChange={() => setScheduleType('later')} /> لاحقًا</label>
                  </div>
                  {scheduleType === 'later' && (
                    <div className='mt-2 grid grid-cols-2 gap-2'>
                      <select value={scheduleDay} onChange={e => setScheduleDay(e.target.value)} className='bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white'>
                        <option value='today'>اليوم</option>
                        <option value='tomorrow'>غدًا</option>
                      </select>
                      <input value={scheduleTime} onChange={e => setScheduleTime(e.target.value)} type='time' className='bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white' />
                    </div>
                  )}
                </div>

                <div className='mb-3'>
                  <p className='text-sm text-zinc-400 mb-2'>عدد الركاب</p>
                  <input value={passengerCount} onChange={e => setPassengerCount(Math.max(1, Math.min(6, Number(e.target.value || 1))))} type='number' min={1} max={6} className='w-24 bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white' />
                </div>

                <div className='mb-3'>
                  <p className='text-sm text-zinc-400 mb-2'>ملاحظات للسائق (اختياري)</p>
                  <textarea value={customerNote} onChange={e => setCustomerNote(e.target.value)} rows={3} className='w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white resize-none' placeholder='مثال: سأحمل شنطة كبيرة' />
                </div>

                <div className='flex items-center justify-between mb-3'>
                  <span className='text-sm text-zinc-400'>حفظ الرحلة في المفضلة</span>
                  <button onClick={onToggleSaveTrip} className={`px-3 py-1.5 rounded-lg text-xs font-bold ${isTripSaved ? 'bg-emerald-600 text-white' : 'bg-zinc-800 text-zinc-300'}`}>
                    {isTripSaved ? 'محفوظة' : 'حفظ'}
                  </button>
                </div>

                <div className='flex gap-2'>
                  <button
                    disabled={requesting}
                    onClick={() => {
                      let scheduledTime = null;
                      if (scheduleType === 'later' && scheduleTime) {
                        const dayOffset = scheduleDay === 'tomorrow' ? 1 : 0;
                        const d = new Date();
                        d.setDate(d.getDate() + dayOffset);
                        const [hh, mm] = scheduleTime.split(':');
                        d.setHours(Number(hh || 0), Number(mm || 0), 0, 0);
                        scheduledTime = d.toISOString();
                      }
                      setShowInfoModal(false);
                      onConfirm && onConfirm({ scheduledTime, customerNote, passengerCount });
                    }}
                    className='flex-1 bg-emerald-600 hover:bg-emerald-500 disabled:opacity-50 text-white rounded-xl py-2'>
                    {requesting ? 'جارِ الإرسال...' : 'تأكيد واطلب'}
                  </button>
                  <button onClick={() => setShowInfoModal(false)} className='flex-1 bg-zinc-800 text-zinc-300 rounded-xl py-2'>إغلاق</button>
                </div>
              </div>
            </div>
          )}
        </>
      )}
    </div>
  );
};
export default TripPlannerPanel;
</file>

